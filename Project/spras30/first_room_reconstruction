ROOM_RECTS = [
    pygame.Rect(20,              TOP_Y,    RW, RH),   # entrance
    pygame.Rect(20 + RW + PAD,   TOP_Y,    RW, RH),   # care
    pygame.Rect(20 + (RW+PAD)*2, TOP_Y,    RW, RH),   # bell
