def draw_glyph(surface, glyph_key, x, y, cell=4, color=(200,185,140)):
    grid = GLYPHS[glyph_key]
    for row_i, row in enumerate(grid):
        for col_i, val in enumerate(row):
            if val:
                pygame.draw.rect(surface, color,
                    (x + col_i*cell, y + row_i*cell, cell-1, cell-1))
 
# ── pixel art room painters ───────────────────────────────────────────────────
def px(surface, color, grid_x, grid_y, w=1, h=1, scale=8):
    pygame.draw.rect(surface, color,
        (grid_x*scale, grid_y*scale, w*scale, h*scale))
 
