def glyph_screen_rect(room_idx):
    r = ROOM_RECTS[room_idx]
    gx, gy = ROOMS[room_idx]["glyph_pos"]
    sx = r.x + int(gx * RW / ROOM_W)
    sy = r.y + int(gy * RH / ROOM_H)
    sw = int(GLYPH_COLS * 3 * RW / ROOM_W)
    sh = int(GLYPH_ROWS * 3 * RH / ROOM_H)
    return pygame.Rect(sx, sy, sw, sh)
 
def draw_rounded_rect(surface, color, rect, radius=6, border=0, border_color=None):
    pygame.draw.rect(surface, color, rect, border_radius=radius)
    if border and border_color:
        pygame.draw.rect(surface, border_color, rect, border, border_radius=radius)
 
# ── draw rooms ────────────────────────────────────────────────────────────────
def draw_rooms(hover_idx, flash_timers):
    for i, room in enumerate(ROOMS):
        r = ROOM_RECTS[i]
        scaled = pygame.transform.scale(room["surface"], (RW, RH))
        WIN.blit(scaled, r.topleft)
 
        gx, gy = room["glyph_pos"]
        sx = r.x + int(gx * RW / ROOM_W)
        sy = r.y + int(gy * RH / ROOM_H)
 
        if room["found"]:
            draw_glyph(WIN, room["glyph_key"], sx, sy, cell=3, color=C_FOUND)
        else:
            draw_glyph(WIN, room["glyph_key"], sx, sy, cell=3, color=room["glyph_color"])
 
        border_col = C_FOUND if room["found"] else (C_ACCENT if i==hover_idx else (55,44,30))
        pygame.draw.rect(WIN, border_col, r, 2, border_radius=3)
 
        lbl = FONT_SMALL.render(room["label"], True, C_FOUND if room["found"] else (120,100,70))
        WIN.blit(lbl, (r.x+5, r.y+4))
 
        if flash_timers.get(i,0) > 0:
            flash_surf = pygame.Surface((RW, RH), pygame.SRCALPHA)
            alpha = min(180, flash_timers[i]*6)
            flash_surf.fill((255,220,80,alpha))
            WIN.blit(flash_surf, r.topleft)
 
        if room["found"]:
            tag = FONT_SMALL.render("✓ found", True, C_FOUND)
            WIN.blit(tag, (r.right - tag.get_width() - 5, r.y+4))
 
def draw_hud():
    found = sum(1 for r in ROOMS if r["found"])
    bar = pygame.Surface((WIDTH,52), pygame.SRCALPHA)
    bar.fill((10,8,5,215))
    WIN.blit(bar,(0,0))
    title = FONT_TITLE.render("ROOM RECONSTRUCTION  ·  Find all 5 hidden symbols", True, C_ACCENT)
    WIN.blit(title,(20,14))
    prog = FONT_BODY.render(f"{found} / 5  symbols found", True, C_TEXT)
    WIN.blit(prog,(WIDTH-prog.get_width()-20,17))
 
def draw_bottom_bar():
    bar = pygame.Surface((WIDTH,44), pygame.SRCALPHA)
    bar.fill((10,8,5,215))
    WIN.blit(bar,(0,HEIGHT-44))
    hint = FONT_SMALL.render(
        "Symbols are hidden in each room — look carefully.  Use the Nazcaän cipher book to decode.",
        True,(100,85,60))
    WIN.blit(hint,(20,HEIGHT-29))
 
# ── collection screen ─────────────────────────────────────────────────────────
def draw_collection_screen(pulse):
    WIN.fill((12,9,6))
 
    title = FONT_TITLE.render("ALL SYMBOLS COLLECTED", True, C_ACCENT)
    WIN.blit(title,(WIDTH//2-title.get_width()//2, 24))
    sub = FONT_BODY.render(
        "Decode each mark using the Nazcaän Script, then unscramble the 5 letters to find the location.",
        True, C_TEXT)
    WIN.blit(sub,(WIDTH//2-sub.get_width()//2, 58))
 
    # 5 panels in a row
    panel_w, panel_h = 160, 220
    total_w = 5 * panel_w + 4 * 12
    start_x = (WIDTH - total_w) // 2
 
    for i, room in enumerate(ROOMS):
        bx = start_x + i * (panel_w + 12)
        by = 100
        panel = pygame.Rect(bx, by, panel_w, panel_h)
        draw_rounded_rect(WIN,(25,20,14),panel,radius=8,border=2,border_color=C_PANEL_BORDER)
 
        lbl_surf = FONT_SMALL.render(room["label"], True,(120,100,70))
        # wrap label if too wide
        WIN.blit(lbl_surf,(bx + panel_w//2 - lbl_surf.get_width()//2, by+8))
 
        # glyph centered
        gx = bx + panel_w//2 - (GLYPH_COLS*6)//2
        gy = by + 38
        draw_glyph(WIN, room["glyph_key"], gx, gy, cell=6, color=C_FOUND)
 
        # pulsing glow
        alpha = int(55+35*math.sin(pulse+i))
        glow = pygame.Surface((GLYPH_COLS*6+16, GLYPH_ROWS*6+16), pygame.SRCALPHA)
        pygame.draw.rect(glow,(*C_ACCENT,alpha),glow.get_rect(),border_radius=6)
        WIN.blit(glow,(gx-8, gy-8))
 
        num = FONT_SMALL.render(f"Symbol {i+1}", True,(80,65,45))
        WIN.blit(num,(bx + panel_w//2 - num.get_width()//2, by+panel_h-22))
 
    footer = FONT_SMALL.render(
        "Use the Nazcaän Script key to decode  →  unscramble the letters  →  find the murder location",
        True,(80,68,50))
    WIN.blit(footer,(WIDTH//2-footer.get_width()//2, HEIGHT-26))
 
# ── main ─────────────────────────────────────────────────────────────────────
def main():
    clock = pygame.time.Clock()
    pulse = 0.0
    flash_timers = {}
    all_found = False
    hover_idx = None
 
    run = True
    while run:
        clock.tick(60)
        pulse += 0.06
        mx, my = pygame.mouse.get_pos()
 
        for k in list(flash_timers):
            flash_timers[k] -= 1
            if flash_timers[k] <= 0:
                del flash_timers[k]
 
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                run = False
            if event.type == pygame.MOUSEBUTTONDOWN and event.button==1:
                if not all_found:
                    for i, room in enumerate(ROOMS):
                        if not room["found"]:
                            hit = glyph_screen_rect(i).inflate(16,16)
                            if hit.collidepoint(mx,my):
                                room["found"] = True
                                flash_timers[i] = 30
                                if all(r["found"] for r in ROOMS):
                                    all_found = True
 
        hover_idx = None
        if not all_found:
            for i in range(len(ROOMS)):
                if ROOM_RECTS[i].collidepoint(mx,my):
                    hover_idx = i; break
 
        pygame.mouse.set_cursor(
            pygame.SYSTEM_CURSOR_CROSSHAIR if hover_idx is not None
            else pygame.SYSTEM_CURSOR_ARROW)
 
        WIN.fill(C_BG)
        if all_found:
            draw_collection_screen(pulse)
        else:
            draw_rooms(hover_idx, flash_timers)
            draw_hud()
            draw_bottom_bar()
 
        pygame.display.update()
 
    pygame.quit()
 
if __name__ == "__main__":
    main()
 