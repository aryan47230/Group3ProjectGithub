     "glyph_pos":(6*8, 1*8+2),"glyph_key":"D","glyph_color":(58,53,48),"found":False,"surface":None},
]

for room in ROOMS:
    surf = pygame.Surface((ROOM_W, ROOM_H))
    room["painter"](surf, ROOM_W, ROOM_H)
    room["surface"] = surf

ROOM_DISPLAY_W, ROOM_DISPLAY_H = 390, 230
ROOM_RECTS = [
    pygame.Rect(30,  80,  ROOM_DISPLAY_W, ROOM_DISPLAY_H),
    pygame.Rect(480, 80,  ROOM_DISPLAY_W, ROOM_DISPLAY_H),
    pygame.Rect(30,  360, ROOM_DISPLAY_W, ROOM_DISPLAY_H),
    pygame.Rect(480, 360, ROOM_DISPLAY_W, ROOM_DISPLAY_H),
]

def glyph_screen_rect(room_idx):
    r = ROOM_RECTS[room_idx]
    gx, gy = ROOMS[room_idx]["glyph_pos"]
    sx = r.x + int(gx * ROOM_DISPLAY_W / ROOM_W)
    sy = r.y + int(gy * ROOM_DISPLAY_H / ROOM_H)
    sw = int(7 * 3 * ROOM_DISPLAY_W / ROOM_W)
    sh = int(9 * 3 * ROOM_DISPLAY_H / ROOM_H)
    return pygame.Rect(sx, sy, sw, sh)

# ── helpers ───────────────────────────────────────────────────────────────────
def draw_rounded_rect(surface, color, rect, radius=6, border=0, border_color=None):
    pygame.draw.rect(surface, color, rect, border_radius=radius)
    if border and border_color:
        pygame.draw.rect(surface, border_color, rect, border, border_radius=radius)

def draw_text_centered(surface, text, font, color, cx, cy):
    s = font.render(text, True, color)
    surface.blit(s, (cx - s.get_width()//2, cy - s.get_height()//2))

# ── draw rooms grid ───────────────────────────────────────────────────────────
def draw_rooms(hover_idx, flash_timers):
    for i, room in enumerate(ROOMS):
        r = ROOM_RECTS[i]
        scaled = pygame.transform.scale(room["surface"], (ROOM_DISPLAY_W, ROOM_DISPLAY_H))
        WIN.blit(scaled, r.topleft)

        gx, gy = room["glyph_pos"]
        sx = r.x + int(gx * ROOM_DISPLAY_W / ROOM_W)
        sy = r.y + int(gy * ROOM_DISPLAY_H / ROOM_H)

        if room["found"]:
            draw_glyph(WIN, room["glyph_key"], sx, sy, cell=3, color=C_FOUND)
        else:
            draw_glyph(WIN, room["glyph_key"], sx, sy, cell=3, color=room["glyph_color"])

        border_col = C_FOUND if room["found"] else (C_ACCENT if i==hover_idx else (55,44,30))
        pygame.draw.rect(WIN, border_col, r, 2, border_radius=3)

        lbl = FONT_SMALL.render(room["label"], True, C_FOUND if room["found"] else (120,100,70))
        WIN.blit(lbl, (r.x+6, r.y+4))

        if flash_timers.get(i,0) > 0:
            flash_surf = pygame.Surface((ROOM_DISPLAY_W, ROOM_DISPLAY_H), pygame.SRCALPHA)
            alpha = min(180, flash_timers[i]*6)
            flash_surf.fill((255,220,80,alpha))
            WIN.blit(flash_surf, r.topleft)

        if room["found"]:
            tag = FONT_SMALL.render("✓ symbol found", True, C_FOUND)
            WIN.blit(tag, (r.right - tag.get_width() - 6, r.y+4))

def draw_hud():
    found = sum(1 for r in ROOMS if r["found"])
    bar = pygame.Surface((WIDTH,52), pygame.SRCALPHA)
    bar.fill((10,8,5,210))
    WIN.blit(bar,(0,0))
    title = FONT_TITLE.render("ROOM RECONSTRUCTION  ·  Find the hidden symbols", True, C_ACCENT)
    WIN.blit(title,(20,13))
    prog = FONT_BODY.render(f"{found} / {len(ROOMS)} found", True, C_TEXT)
    WIN.blit(prog,(WIDTH-prog.get_width()-20,16))

def draw_bottom_bar():
    bar = pygame.Surface((WIDTH,52), pygame.SRCALPHA)
    bar.fill((10,8,5,210))
    WIN.blit(bar,(0,HEIGHT-52))
    hint = FONT_SMALL.render(
        "Click carefully — symbols are hidden in each scene.  Use your cipher book to decode them.",
        True,(100,85,60))
    WIN.blit(hint,(20,HEIGHT-36))

# ── collection screen ─────────────────────────────────────────────────────────
def draw_collection_screen(pulse):
    WIN.fill((12,9,6))
    title = FONT_TITLE.render("SYMBOLS COLLECTED", True, C_ACCENT)
    WIN.blit(title,(WIDTH//2-title.get_width()//2,30))
    sub = FONT_BODY.render(
        "Use your cipher book to decode these marks and unscramble the location.",
        True, C_TEXT)
    WIN.blit(sub,(WIDTH//2-sub.get_width()//2,68))

    for i, room in enumerate(ROOMS):
        col = i%2; row = i//2
        bx = 120 + col*340; by = 130 + row*210
        panel = pygame.Rect(bx,by,260,180)
        draw_rounded_rect(WIN,(25,20,14),panel,radius=8,border=2,border_color=C_PANEL_BORDER)
        lbl = FONT_SMALL.render(room["label"], True,(120,100,70))
        WIN.blit(lbl,(bx+10,by+8))
        gx = bx+130-(7*7)//2; gy = by+50
        draw_glyph(WIN,room["glyph_key"],gx,gy,cell=7,color=C_FOUND)
        alpha = int(60+40*math.sin(pulse+i))
        glow = pygame.Surface((7*7+20,9*7+20),pygame.SRCALPHA)
        pygame.draw.rect(glow,(*C_ACCENT,alpha),glow.get_rect(),border_radius=6)
        WIN.blit(glow,(gx-10,gy-10))
        note = FONT_SMALL.render("Symbol #"+str(i+1), True,(90,75,55))
        WIN.blit(note,(bx+10,by+160))

    footer = FONT_SMALL.render(
        "These 4 symbols represent letters in the unknown language  —  decode, then unscramble.",
        True,(80,68,50))
    WIN.blit(footer,(WIDTH//2-footer.get_width()//2,HEIGHT-30))

# ── main ─────────────────────────────────────────────────────────────────────
def main():
    clock = pygame.time.Clock()
    pulse = 0.0
    flash_timers = {}
    all_found = False
    hover_idx = None

    run = True
    while run:
        clock.tick(60)
        pulse += 0.06
        mx,my = pygame.mouse.get_pos()

        for k in list(flash_timers):
            flash_timers[k] -= 1
            if flash_timers[k] <= 0:
                del flash_timers[k]

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                run = False
            if event.type == pygame.MOUSEBUTTONDOWN and event.button==1:
                if not all_found:
                    for i,room in enumerate(ROOMS):
                        if not room["found"]:
                            hit = glyph_screen_rect(i).inflate(14,14)
                            if hit.collidepoint(mx,my):
                                room["found"] = True
                                flash_timers[i] = 30
                                if all(r["found"] for r in ROOMS):
                                    all_found = True

        hover_idx = None
        if not all_found:
            for i in range(len(ROOMS)):
                if ROOM_RECTS[i].collidepoint(mx,my):
                    hover_idx = i; break

        pygame.mouse.set_cursor(
            pygame.SYSTEM_CURSOR_CROSSHAIR if hover_idx is not None
            else pygame.SYSTEM_CURSOR_ARROW)

        WIN.fill(C_BG)
        if all_found:
            draw_collection_screen(pulse)
        else:
            draw_rooms(hover_idx, flash_timers)
            draw_hud()
            draw_bottom_bar()

        pygame.display.update()

    pygame.quit()

if __name__ == "__main__":
    main()