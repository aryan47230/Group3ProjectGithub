def draw_glyph(surface, glyph_key, x, y, cell=4, color=(200,185,140)):
    grid = GLYPHS[glyph_key]
    for row_i, row in enumerate(grid):
        for col_i, val in enumerate(row):
            if val:
                pygame.draw.rect(surface, color,
                    (x + col_i*cell, y + row_i*cell, cell-1, cell-1))

# ── pixel art room painters ───────────────────────────────────────────────────
def px(surface, color, grid_x, grid_y, w=1, h=1, scale=8):
    pygame.draw.rect(surface, color,
        (grid_x*scale, grid_y*scale, w*scale, h*scale))

def draw_room_care(surface, W, H):
    s=8
    for gx in range(W//s):
        for gy in range(H//s):
            c=(45,38,30) if (gx+gy)%2==0 else (40,33,26)
            px(surface,c,gx,gy)
    for gx in range(W//s):
        for gy in range(4):
            px(surface,(55,48,40),gx,gy)
    for gx in range(8,20):
        for gy in range(1,4):
            px(surface,(200,210,200),gx,gy)
    pygame.draw.rect(surface,(80,80,80),(8*s,1*s,12*s,3*s),2)
    for gx in range(4,24):
        px(surface,(100,75,50),gx,9)
    for gx in range(5,23):
        for gy in range(10,13):
            px(surface,(120,90,60),gx,gy)
    for gx in range(6,10):
        px(surface,(70,55,40),gx,13)
    for gx in range(6,10):
        for gy in range(14,17):
            px(surface,(80,60,45),gx,gy)
    for gx in range(11,16):
        for gy in range(7,9):
            px(surface,(60,60,70),gx,gy)
    for gx in range(11,16):
        px(surface,(40,40,50),gx,9)
    colors=[(160,40,40),(40,100,160),(40,140,80)]
    for i,bc in enumerate(colors):
        for gy in range(9,12):
            px(surface,bc,19+i,gy)
    for gx in range(23,27):
        for gy in range(1,4):
            px(surface,(140,180,210),gx,gy)
    pygame.draw.rect(surface,(80,70,55),(23*s,1*s,4*s,3*s),2)

def draw_room_bell(surface, W, H):
    s=8
    for gx in range(W//s):
        for gy in range(H//s):
            shade=50+((gx*3+gy*7)%15)
            px(surface,(shade,shade-5,shade-10),gx,gy)
    for gx in range(W//s):
        for gy in range(5):
            shade=70+(gx%4)*5
            px(surface,(shade,shade-3,shade-8),gx,gy)
    for gx in range(9,21):
        for gy in range(3,6):
            px(surface,(120,170,210),gx,gy)
    pygame.draw.polygon(surface,(180,150,50),[
        (14*s,1*s),(18*s,1*s),(20*s,4*s),(12*s,4*s)])
    pygame.draw.circle(surface,(160,130,40),(16*s,4*s),s//2)
    for gy in range(H//s):
        px(surface,(90,80,70),2,gy,2,1)
    for gy in range(H//s):
        px(surface,(90,80,70),26,gy,2,1)
    for gx in range(0,W//s,4):
        pygame.draw.line(surface,(60,55,50),(gx*s,5*s),(gx*s,H),1)

def draw_room_balcony(surface, W, H):
    s=8
    for gy in range(H//s):
        t=gy/(H//s)
        r=int(30+t*20); g=int(40+t*25); b=int(60+t*30)
        for gx in range(W//s):
            px(surface,(r,g,b),gx,gy)
    for gx in range(W//s):
        for gy in range(14,H//s):
            px(surface,(70,60,50),gx,gy)
    for gx in range(0,W//s,3):
        for gy in range(10,14):
            px(surface,(100,90,80),gx,gy)
    for gx in range(W//s):
        px(surface,(120,110,100),gx,10)
    glass=pygame.Surface((28*s,3*s),pygame.SRCALPHA)
    glass.fill((140,180,220,60))
    surface.blit(glass,(0,11*s))
    for bx,bw,bh,bc in [(0,4,6,(40,50,60)),(5,3,8,(35,45,55)),
                         (9,5,5,(45,55,65)),(20,6,7,(38,48,58)),(27,3,4,(42,52,62))]:
        for gx in range(bx,bx+bw):
            for gy in range(10-bh,10):
                px(surface,bc,gx,gy)
    for gx in range(24,27):
        px(surface,(100,70,40),gx,13)
    for gy in range(12,14):
        for gx in range(24,27):
            px(surface,(110,80,50),gx,gy)
    pygame.draw.circle(surface,(40,100,50),(25*s,11*s),s+2)
    pygame.draw.circle(surface,(35,90,45),(26*s,10*s),s)

def draw_room_cbtf(surface, W, H):
    s=8
    for gx in range(W//s):
        for gy in range(H//s):
            c=28+(gx+gy)%6
            px(surface,(c,c-2,c-4),gx,gy)
    for gx in range(W//s):
        px(surface,(60,55,50),gx,0)
        if gx%6==0:
            for gy in range(1,3):
                px(surface,(70,65,55),gx,gy)
    for row in range(2):
        base_y=6+row*7
        for col in range(4):
            base_x=2+col*7
            for gx in range(base_x,base_x+5):
                px(surface,(55,45,35),gx,base_y+3)
            for gx in range(base_x+1,base_x+4):
                for gy in range(base_y,base_y+3):
                    px(surface,(30,80,50),gx,gy)
            px(surface,(60,180,100),base_x+2,base_y+1)
            px(surface,(50,45,40),base_x+2,base_y+3)
    pygame.draw.circle(surface,(180,40,40),(2*s,2*s),s//2)

