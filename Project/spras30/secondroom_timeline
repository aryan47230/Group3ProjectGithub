def draw_solved_overlay(elev_open_pct):
    overlay = pygame.Surface((WIDTH,HEIGHT),pygame.SRCALPHA)
    overlay.fill((0,0,0,int(80*elev_open_pct)))
    WIN.blit(overlay,(0,0))
    if elev_open_pct > 0.3:
        msg = FONT_BIG.render("The bell rings!", True, C_BELL_RING)
        WIN.blit(msg,(WIDTH//2-msg.get_width()//2,130))
    if elev_open_pct > 0.6:
        sub = FONT_BODY.render("The elevator opens — proceed to the 3rd floor.", True, C_TEXT)
        WIN.blit(sub,(WIDTH//2-sub.get_width()//2,175))

# ── main loop ─────────────────────────────────────────────────────────────────
def main():
    global dragging_id, drag_offset, drag_pos, drag_source
    global bell_shake, bell_color, bell_ring, elev_open, solved, slots, tray_order

    clock = pygame.time.Clock()
    tick = 0

    run = True
    while run:
        dt = clock.tick(60) / 1000.0
        tick += 1
        mx,my = pygame.mouse.get_pos()

        # decay timers
        if bell_shake > 0:
            bell_shake = max(0.0, bell_shake - dt*4)
            bell_color = C_WRONG if bell_shake > 0.1 else C_BELL_IDLE
        if bell_ring > 0:
            bell_ring = max(0.0, bell_ring - dt*0.5)
            bell_color = C_BELL_RING
        if solved and elev_open < 1.0:
            elev_open = min(1.0, elev_open + dt*0.4)

        # ── events ──
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                run = False

            if event.type == pygame.MOUSEBUTTONDOWN and event.button==1 and not solved:
                # check slots
                for si in range(4):
                    sr = slot_rect(si)
                    if sr.collidepoint(mx,my) and slots[si] is not None:
                        dragging_id  = slots[si]
                        drag_source  = ("slot", si)
                        drag_offset  = (mx-(sr.x+5), my-(sr.y+5))
                        drag_pos     = (mx-drag_offset[0], my-drag_offset[1])
                        slots[si]    = None
                        break
                else:
                    # check tray
                    for ti, iid in enumerate(tray_order):
                        if iid is not None:
                            tr = tray_rect(ti)
                            if tr.collidepoint(mx,my):
                                dragging_id = iid
                                drag_source = ("tray", ti)
                                drag_offset = (mx-tr.x, my-tr.y)
                                drag_pos    = (mx-drag_offset[0], my-drag_offset[1])
                                tray_order[ti] = None
                                break

            if event.type == pygame.MOUSEMOTION and dragging_id is not None:
                drag_pos = (mx-drag_offset[0], my-drag_offset[1])

            if event.type == pygame.MOUSEBUTTONUP and event.button==1 and dragging_id is not None:
                placed = False
                # try to drop on a slot
                for si in range(4):
                    sr = slot_rect(si)
                    if sr.inflate(20,20).collidepoint(mx,my):
                        if slots[si] is None:
                            slots[si] = dragging_id
                            placed = True
                        else:
                            # swap
                            displaced = slots[si]
                            slots[si] = dragging_id
                            # put displaced back in tray
                            for ti in range(4):
                                if tray_order[ti] is None:
                                    tray_order[ti] = displaced
                                    break
                            placed = True
                        break
                if not placed:
                    # return to tray
                    for ti in range(4):
                        if tray_order[ti] is None:
                            tray_order[ti] = dragging_id
                            break
                dragging_id = None
                drag_source = None

                # check if all slots filled → validate
                if all(s is not None for s in slots):
                    if check_correct():
                        solved   = True
                        bell_ring = 2.0
                        bell_color= C_BELL_RING
                    else:
                        bell_shake = 1.4
                        bell_color = C_WRONG

        # ── draw ──
        draw_bg()
        draw_hud()
        draw_labels()

        # elevator on right wall
        draw_elevator(WIN, WIDTH-130, HEIGHT-200, 90, 165, open_pct=elev_open)

        # bell — top center, animated
        bell_anim = bell_ring if bell_ring > 0 else bell_shake
        draw_bell_simple(WIN, WIDTH//2, 90, bell_color, shake=bell_anim * 6)

        # slots
        for si in range(4):
            sr = slot_rect(si)
            occupied = slots[si] is not None
            correct  = slot_correctness(si) if occupied else None
            draw_slot(WIN, si, sr.x, sr.y, occupied=occupied, correct=correct)
            if occupied:
                draw_card(WIN, item_by_id(slots[si]), sr.x+5, sr.y+5,
                          highlighted=False)

        # tray cards
        for ti, iid in enumerate(tray_order):
            if iid is not None:
                tr = tray_rect(ti)
                hovered = tr.collidepoint(mx,my) and dragging_id is None
                draw_card(WIN, item_by_id(iid), tr.x, tr.y, highlighted=hovered)

        # dragging card — on top of everything
        if dragging_id is not None:
            draw_card(WIN, item_by_id(dragging_id), drag_pos[0], drag_pos[1],
                      highlighted=True, dragging=True)
            pygame.mouse.set_cursor(pygame.SYSTEM_CURSOR_HAND)
        else:
            # hover cursor
            hovering = any(slot_rect(si).collidepoint(mx,my) and slots[si] is not None for si in range(4))
            hovering = hovering or any(
                tray_rect(ti).collidepoint(mx,my) for ti,iid in enumerate(tray_order) if iid is not None)
            pygame.mouse.set_cursor(
                pygame.SYSTEM_CURSOR_HAND if hovering else pygame.SYSTEM_CURSOR_ARROW)

        if solved:
            draw_solved_overlay(elev_open)

        pygame.display.update()

    pygame.quit()

if __name__ == "__main__":
    main()