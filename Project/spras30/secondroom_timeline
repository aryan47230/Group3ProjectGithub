# ── pixel art icon drawers ────────────────────────────────────────────────────
def draw_icon_camera(surface, cx, cy, size=28, color=(160,190,220)):
    s = size
    # body
    pygame.draw.rect(surface, color,        (cx-s//2,   cy-s//3,   s,     s*2//3), border_radius=3)
    pygame.draw.rect(surface, (color[0]//2, color[1]//2, color[2]//2), (cx-s//2, cy-s//3, s, s*2//3), 1, border_radius=3)
    # lens
    pygame.draw.circle(surface, (30,30,40), (cx, cy), s//4+1)
    pygame.draw.circle(surface, (50,80,120),(cx, cy), s//4-1)
    pygame.draw.circle(surface, (100,150,200),(cx-2,cy-2), 3)
    # viewfinder bump
    pygame.draw.rect(surface, color, (cx-4, cy-s//3-6, 8, 6), border_radius=2)

def draw_icon_phone(surface, cx, cy, size=28, color=(140,200,140)):
    s = size
    pygame.draw.rect(surface, color, (cx-s//3, cy-s//2, s*2//3, s), border_radius=5)
    pygame.draw.rect(surface, (color[0]//2, color[1]//2, color[2]//2), (cx-s//3, cy-s//2, s*2//3, s), 1, border_radius=5)
    pygame.draw.rect(surface, (20,30,20), (cx-s//3+3, cy-s//2+6, s*2//3-6, s-16))
    pygame.draw.circle(surface, color, (cx, cy+s//2-5), 4)

def draw_icon_receipt(surface, cx, cy, size=28, color=(200,185,140)):
    s = size
    # paper
    pygame.draw.rect(surface, color, (cx-s//3, cy-s//2, s*2//3, s))
    # lines of text
    for i in range(4):
        y = cy - s//2 + 6 + i*7
        w = [s//2-4, s//3, s//2-6, s//4][i]
        pygame.draw.rect(surface, (120,110,80), (cx-w//2, y, w, 3))
    # zigzag bottom
    pts = []
    bx = cx - s//3; by = cy + s//2
    step = 4
    for j in range((s*2//3)//step + 1):
        pts.append((bx + j*step, by - (4 if j%2==0 else 0)))
    if len(pts) > 1:
        pygame.draw.lines(surface, color, False, pts, 2)

def draw_icon_watch(surface, cx, cy, size=28, color=(200,170,120)):
    s = size
    # band top/bottom
    pygame.draw.rect(surface, (80,60,40), (cx-4, cy-s//2-6, 8, 8), border_radius=2)
    pygame.draw.rect(surface, (80,60,40), (cx-4, cy+s//2-2, 8, 8), border_radius=2)
    # face
    pygame.draw.circle(surface, (30,25,20), (cx,cy), s//2+1)
    pygame.draw.circle(surface, color,      (cx,cy), s//2)
    pygame.draw.circle(surface, (20,16,10), (cx,cy), s//2-3)
    # hands — stopped at ~1:58 → hour near 2, minute near 58
    # minute hand (nearly 12 — 58 min ≈ 348 deg)
    angle_m = math.radians(348 - 90)
    pygame.draw.line(surface, (220,200,150),
        (cx,cy), (cx+int(math.cos(angle_m)*(s//2-4)), cy+int(math.sin(angle_m)*(s//2-4))), 1)
    # hour hand (~2:00 = 60 deg)
    angle_h = math.radians(60 - 90)
    pygame.draw.line(surface, (220,200,150),
        (cx,cy), (cx+int(math.cos(angle_h)*(s//2-8)), cy+int(math.sin(angle_h)*(s//2-8))), 2)
    # crack across face
    pygame.draw.line(surface, (80,60,40), (cx-4, cy-6), (cx+6, cy+4), 1)

