# ── pixel art bell ─────────────────────────────────────────────────────────────
def draw_bell(surface, cx, cy, scale=1.0, color=C_BELL_IDLE, shake=0):
    ox = int(math.sin(shake * 0.8) * 6 * scale) if shake > 0 else 0
    cx += ox
    s = int(38 * scale)
    # mounting bracket
    pygame.draw.rect(surface, (80,70,55), (cx-6, cy-s-10, 12, 10), border_radius=2)
    # bell body (trapezoid)
    pts = [
        (cx - s//2,    cy),
        (cx + s//2,    cy),
        (cx + s*3//4,  cy + s*2//3),
        (cx - s*3//4,  cy + s*2//3),
    ]
    pygame.draw.polygon(surface, color, pts)
    pygame.draw.polygon(surface, (127, 100, 40), pts, 2)
    # bell rim
    pygame.draw.ellipse(surface, (max(0,color[0]-20), max(0,color[1]-20), max(0,color[2]-20)),
                        (cx-s*3//4, cy+s*2//3-5, s*3//2, 12))
    pygame.draw.ellipse(surface, color, (cx-s*3//4+2, cy+s*2//3-3, s*3//2-4, 8))
    # clapper
    pygame.draw.line(surface, (100,85,50), (cx, cy+s//4), (cx+ox, cy+s*2//3-2), 2)
    pygame.draw.circle(surface, (140,115,60), (cx+ox, cy+s*2//3), 5)
    # shine
    pygame.draw.ellipse(surface, (min(255,color[0]+60), min(255,color[1]+50), min(255,color[2]+20)),
                        (cx-s//4, cy+4, s//5, s//4))

def draw_bell_simple(surface, cx, cy, color, shake=0):
    ox = int(math.sin(shake*0.8)*6) if shake > 0 else 0
    x = cx + ox
    s = 36
    pygame.draw.rect(surface,(80,70,55),(x-5,cy-s-8,10,10),border_radius=2)
    pts=[(x-s//2,cy),(x+s//2,cy),(x+s*3//4,cy+s*2//3),(x-s*3//4,cy+s*2//3)]
    pygame.draw.polygon(surface,color,pts)
    pygame.draw.polygon(surface,(min(255,color[0]+40),min(255,color[1]+35),min(255,color[2]+10)),pts,2)
    pygame.draw.ellipse(surface,(max(0,color[0]-30),max(0,color[1]-25),max(0,color[2]-10)),
                        (x-s*3//4,cy+s*2//3-4,s*3//2,10))
    pygame.draw.line(surface,(100,85,50),(x,cy+10),(x+ox//2,cy+s*2//3-2),2)
    pygame.draw.circle(surface,(140,115,60),(x+ox//2,cy+s*2//3),5)
    pygame.draw.ellipse(surface,(min(255,color[0]+60),min(255,color[1]+50),min(255,color[2]+20)),
                        (x-8,cy+5,8,12))

# ── pixel art elevator doors ──────────────────────────────────────────────────
def draw_elevator(surface, x, y, w, h, open_pct=0.0):
    # frame
    pygame.draw.rect(surface,(60,52,40),(x-4,y-4,w+8,h+8),border_radius=4)
    # doors
    door_w = int((w//2) * (1.0 - open_pct))
    # left door
    pygame.draw.rect(surface,C_ELEVATOR,(x, y, door_w, h))
    if door_w > 2:
        pygame.draw.rect(surface,(70,62,48),(x,y,door_w,h),1)
        for dy in range(0,h,20):
            pygame.draw.line(surface,(55,48,37),(x+2,y+dy),(x+door_w-2,y+dy),1)
    # right door
    rx = x + w - door_w
    pygame.draw.rect(surface,C_ELEVATOR,(rx,y,door_w,h))
    if door_w > 2:
        pygame.draw.rect(surface,(70,62,48),(rx,y,door_w,h),1)
        for dy in range(0,h,20):
            pygame.draw.line(surface,(55,48,37),(rx+2,y+dy),(rx+door_w-2,y+dy),1)
    # gap / interior when open
    if open_pct > 0.05:
        interior_x = x + door_w
        interior_w = w - door_w*2
        if interior_w > 0:
            pygame.draw.rect(surface,(28,22,14),(interior_x,y,interior_w,h))
            # interior light
            pygame.draw.rect(surface,(60,50,30),(interior_x,y,interior_w,6))
    # button panel
    pygame.draw.rect(surface,(50,42,30),(x+w+8,y+h//2-20,18,40),border_radius=3)
    for bi,bc in enumerate([(80,160,80),(160,80,80)]):
        pygame.draw.circle(surface,bc,(x+w+17,y+h//2-8+bi*18),5)
    # floor indicator
    surf = FONT_TINY.render("2F", True, C_ACCENT)
    WIN.blit(surf,(x+w//2-surf.get_width()//2, y-20))

# ── card drawing ──────────────────────────────────────────────────────────────
CARD_W, CARD_H = 150, 185

def draw_card(surface, item, x, y, highlighted=False, dragging=False):
    col = item["color"]
    alpha = 230 if dragging else 255
    shadow_offset = 8 if dragging else 3
    # shadow
    shadow = pygame.Surface((CARD_W, CARD_H), pygame.SRCALPHA)
    shadow.fill((0,0,0,60))
    surface.blit(shadow,(x+shadow_offset, y+shadow_offset))
    # card body
    card = pygame.Surface((CARD_W, CARD_H), pygame.SRCALPHA)
    pygame.draw.rect(card,(*C_PANEL,alpha),(0,0,CARD_W,CARD_H),border_radius=8)
    # colored top strip
    pygame.draw.rect(card,(*col,alpha),(0,0,CARD_W,44),border_radius=8)
    pygame.draw.rect(card,(0,0,0,0),(0,22,CARD_W,22))  # square off bottom of strip
    pygame.draw.rect(card,(*col,alpha),(0,22,CARD_W,22))
    surface.blit(card,(x,y))
    # border
    border_col = C_BORDER_HI if highlighted else C_BORDER
    pygame.draw.rect(surface, border_col,(x,y,CARD_W,CARD_H),2,border_radius=8)
    # icon
    ICON_DRAWERS[item["icon"]](surface, x+CARD_W//2, y+22, size=26,
                               color=(min(255,col[0]+80),min(255,col[1]+80),min(255,col[2]+80)))
    # divider
    pygame.draw.line(surface,C_BORDER,(x+10,y+48),(x+CARD_W-10,y+48),1)
    # time — big
    t_surf = FONT_TIME.render(item["time"], True, C_ACCENT)
    surface.blit(t_surf,(x+CARD_W//2-t_surf.get_width()//2, y+54))
    # name
    name_surf = FONT_TINY.render(item["name"], True, C_TEXT)
    surface.blit(name_surf,(x+CARD_W//2-name_surf.get_width()//2, y+80))
    # detail lines
    for li, line in enumerate(item["detail"].split("\n")):
        d_surf = FONT_TINY.render(line, True, C_DIM)
        surface.blit(d_surf,(x+CARD_W//2-d_surf.get_width()//2, y+98+li*14))
    # drag handle dots
    if not dragging:
        for di in range(3):
            pygame.draw.circle(surface,(80,65,45),(x+CARD_W//2-12+di*12, y+CARD_H-14),2)

# ── slot drawing ──────────────────────────────────────────────────────────────
SLOT_W, SLOT_H = CARD_W + 10, CARD_H + 10
SLOT_LABELS = ["1st", "2nd", "3rd", "4th"]

def draw_slot(surface, idx, x, y, occupied=False, correct=None):
    col = C_CORRECT if correct==True else (C_WRONG if correct==False else C_SLOT_BORDER)
    pygame.draw.rect(surface, C_SLOT_EMPTY, (x,y,SLOT_W,SLOT_H), border_radius=8)
    pygame.draw.rect(surface, col,          (x,y,SLOT_W,SLOT_H), 2, border_radius=8)
    if not occupied:
        lbl = FONT_BODY.render(SLOT_LABELS[idx], True,(50,40,25))
        surface.blit(lbl,(x+SLOT_W//2-lbl.get_width()//2, y+SLOT_H//2-lbl.get_height()//2))

# ── state ─────────────────────────────────────────────────────────────────────
# slots: list of item id or None
slots = [None, None, None, None]
# tray: unplaced items  (start with all 4 shuffled)
import random
tray_order = [0,1,2,3]
random.shuffle(tray_order)

dragging_id   = None   # item id being dragged
drag_offset   = (0,0)
drag_pos      = (0,0)
drag_source   = None   # ("slot", idx) or ("tray", idx)

bell_shake    = 0.0    # countdown timer for shake
bell_color    = C_BELL_IDLE
bell_ring     = 0.0    # countdown for ring animation
elev_open     = 0.0    # 0..1
solved        = False

# layout
TRAY_Y       = 450
SLOT_Y       = 220
SLOTS_START_X = (WIDTH - (4*SLOT_W + 3*20)) // 2
TRAY_START_X  = (WIDTH - (4*(CARD_W+12))) // 2

def slot_rect(idx):
    return pygame.Rect(SLOTS_START_X + idx*(SLOT_W+20), SLOT_Y, SLOT_W, SLOT_H)

def tray_rect(tray_idx):
    return pygame.Rect(TRAY_START_X + tray_idx*(CARD_W+12), TRAY_Y, CARD_W, CARD_H)

def item_by_id(iid):
    return next(i for i in ITEMS if i["id"]==iid)

def check_correct():
    for slot_idx, item_id in enumerate(slots):
        if item_id is None: return False
        if item_by_id(item_id)["correct_pos"] != slot_idx:
            return False
    return True

def slot_correctness(slot_idx):
    iid = slots[slot_idx]
    if iid is None: return None
    return item_by_id(iid)["correct_pos"] == slot_idx

